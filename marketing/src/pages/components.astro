---
import Base from '../layouts/Base.astro';

/**
 * Components — level-2 naming of the harness's reusable pieces: named,
 * finance-specific, inspectable, linking the public repos. Deliberately
 * NOT product pages (no packaging/install-path/pricing claims) — that is
 * a later, separately-gated step.
 */

interface Component {
  name: string;
  repo: string;
  repoLabel: string;
  license: string;
  maturity: string;
  body: string;
}

const components: Component[] = [
  {
    name: 'Evaluator',
    repo: 'https://github.com/cipher813/alpha-engine-evaluator',
    repoLabel: 'alpha-engine-evaluator',
    license: 'MIT',
    maturity: 'In production — grades the live system weekly.',
    body: 'The flagship component: a finance-specific evaluation layer for agentic systems. A typed metric-record contract (value, confidence interval, sample size, target and red-line, trend, and honest N/A semantics when the data can’t support a grade) feeds a seven-tile weekly report card across portfolio outcome, predictor, research, executor, backtester, substrate, and agent quality. On top sits a Director agent that reads the graded card and proposes a weekly action plan — through a human-approved pull request, never a live config write.',
  },
  {
    name: 'Financial RAG pipeline',
    repo: 'https://github.com/cipher813/alpha-engine-data',
    repoLabel: 'alpha-engine-data',
    license: 'Public repo',
    maturity: 'In production — refreshed weekly before every research run.',
    body: 'Retrieval over a financial corpus built for agent consumption: SEC filings, 8-Ks, and earnings transcripts ingested weekly into serverless Postgres + pgvector with finance-tuned embeddings, plus rolling investment theses so research agents retrieve their own prior reasoning alongside the primary sources.',
  },
  {
    name: 'Backtester & statistical promotion machinery',
    repo: 'https://github.com/cipher813/alpha-engine-backtester',
    repoLabel: 'alpha-engine-backtester',
    license: 'Public repo',
    maturity: 'In production — runs the weekly evaluation and optimization cycle.',
    body: 'Signal-quality evaluation and parameter optimization with the statistical discipline most retail backtesters skip: combinatorial purged cross-validation with purge and embargo, deflated Sharpe (DSR/PSR) with logged trial counts, BH-FDR multiplicity screening, and holdout validation before any optimized parameter is written back to the live system.',
  },
  {
    name: 'Shared library',
    repo: 'https://github.com/cipher813/alpha-engine-lib',
    repoLabel: 'alpha-engine-lib',
    license: 'Public repo, on PyPI',
    maturity: 'In production — pinned across the fleet.',
    body: 'The cross-repo primitives the harness standardizes on: the metric-record contract, quant statistics (deflated Sharpe, leak-free CV helpers), dual-track trading-day date handling, fail-loud alerting, and the phase/manifest registry that makes pipeline status markers unable to lie.',
  },
];
---

<Base
  title="Components — Nous Ergon"
  description="The reusable pieces of the harness: a finance-specific evaluation layer (MIT), a financial RAG pipeline, statistical promotion machinery, and the shared library — named, inspectable, public."
>
  <section class="max-w-3xl mx-auto px-6 pt-12 pb-10">
    <h1 class="text-2xl md:text-3xl font-semibold text-zinc-100 mb-4">Components</h1>
    <p class="text-sm md:text-base text-zinc-400 leading-relaxed mb-4">
      The harness decomposes into reusable, finance-specific components. Each
      is named, inspectable, and public &mdash; the repos below are the
      authoritative source. They are infrastructure the experiments run on,
      shared as working code rather than packaged products.
    </p>
    <p class="text-sm md:text-base text-zinc-400 leading-relaxed">
      For the design rationale behind the tool choices, see
      <a class="text-sky-400 hover:text-sky-300 transition" href="/stack">Stack</a>;
      for how the pieces wire together, see
      <a class="text-sky-400 hover:text-sky-300 transition" href="/architecture">Architecture</a>.
    </p>
  </section>

  <section class="max-w-3xl mx-auto px-6 pb-16 space-y-6">
    {
      components.map((c) => (
        <article class="rounded-lg border border-white/10 bg-white/[0.03] p-5">
          <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-2">
            <h2 class="text-sm md:text-base font-semibold text-zinc-100">{c.name}</h2>
            <a
              class="text-[12px] text-sky-400 hover:text-sky-300 transition font-mono"
              target="_blank"
              rel="noopener noreferrer"
              href={c.repo}
            >
              {c.repoLabel}
            </a>
            <span class="text-[11px] uppercase tracking-wider text-zinc-500">{c.license}</span>
          </div>
          <p class="text-sm text-zinc-400 leading-relaxed mb-2">{c.body}</p>
          <p class="text-[12px] text-zinc-500">{c.maturity}</p>
        </article>
      ))
    }
  </section>
</Base>
