---
import Base from '../layouts/Base.astro';

interface StackEntry {
  name: string;
  body: string;
}

interface StackSection {
  heading: string;
  entries: StackEntry[];
}

const sections: StackSection[] = [
  {
    heading: 'Foundation',
    entries: [
      {
        name: 'Python',
        body: 'Primary language across all eight repos. Lambda runs 3.12; local development on 3.13.',
      },
      {
        name: 'AWS',
        body: 'Step Functions orchestrate the pipelines, Lambda runs the stateless work, EC2 hosts the stateful executor and batch jobs, S3 is the inter-module data bus, CloudFormation owns the infrastructure. Per-service breakdown in *Compute & orchestration* below.',
      },
      {
        name: 'Anthropic Claude',
        body: 'Tiered usage — Haiku for per-ticker quant, qual, and peer-review (~12 calls per Saturday run); Sonnet only for synthesis (macro economist, CIO batch evaluation, nuanced judge cases). Sonnet is ~5× Haiku; reserving it for synthesis keeps per-run cost stable.',
      },
      {
        name: 'Streamlit',
        body: 'Live data console at `live.nousergon.ai` and the private interview-demo console at `console.nousergon.ai`. Pragmatic pick for read-only monitoring: a custom React dashboard would be weeks of work for the same outcome.',
      },
    ],
  },
  {
    heading: 'Agentic layer',
    entries: [
      {
        name: 'LangGraph',
        body: 'Multi-agent orchestration with `Send()` fan-out semantics and custom dict-keyed reducers. Six sector teams + macro economist + CIO + LLM-as-judge run as graph nodes with typed state. Vanilla LangChain doesn\'t compose for parallel multi-team coordination with state merging.',
      },
      {
        name: 'LangSmith',
        body: 'Auto-tracing on every production LLM call. The trajectory validator polls LangSmith for graph-correctness invariants (required nodes present, sector_team_node appears exactly 6 times) post-`graph.invoke()`. Free tier covers a personal-scale workload.',
      },
      {
        name: 'Pydantic',
        body: 'Typed agent outputs (`with_structured_output(..., include_raw=True)` with strict-mode parse-error contract across every LLM-output site).',
      },
    ],
  },
  {
    heading: 'Data & retrieval',
    entries: [
      {
        name: 'ArcticDB (over parquet on S3)',
        body: 'Feature store for ~50 features × ~900 tickers × 10y. Migration was driven by a real performance bottleneck: per-feature parquet scans on S3 were slow on the read side and OOMed c5.large training instances. ArcticDB\'s symbol-keyed range queries pull only the slice each consumer needs.',
      },
      {
        name: 'Neon — serverless Postgres + pgvector',
        body: 'RAG corpus for SEC filings, 8-Ks, earnings transcripts, and rolling investment theses. HNSW indexing for fast vector search; serverless tier means no idle compute cost when the weekly research run isn\'t firing.',
      },
      {
        name: 'Voyage `voyage-3-lite`',
        body: '512-dimensional embeddings tuned for financial-domain text. Cheaper than OpenAI\'s `text-embedding-3-*` tier with better fit on the SEC-filing corpus the qual agents retrieve over.',
      },
      {
        name: 'Polygon.io',
        body: 'Primary market-data source for adjusted OHLCV and intraday data; yfinance retained as cross-validation only, not as a silent fallback (silent-fallback patterns have been a repeat offender for masking real failures and were retired across the data layer).',
      },
      {
        name: 'FRED + FMP',
        body: 'Macro indicators and supplemental fundamentals.',
      },
      {
        name: 'VectorBT',
        body: 'Historical portfolio simulation in the backtester.',
      },
    ],
  },
  {
    heading: 'ML tools',
    entries: [
      {
        name: 'LightGBM',
        body: 'Layer-1 gradient-boosted models in the predictor meta-ensemble (momentum + volatility).',
      },
      {
        name: 'pandas + numpy',
        body: 'Feature engineering, signal scoring, metric computation.',
      },
    ],
  },
  {
    heading: 'Compute & orchestration',
    entries: [
      {
        name: 'AWS Step Functions (over Airflow / Dagster / Prefect)',
        body: 'Three pipelines (Saturday weekly research, weekday morning, EOD post-close) orchestrated as state machines. Native to the AWS account that already runs Lambda + EC2 + S3, so no new infrastructure to operate. Execution history is itself the audit trail.',
      },
      {
        name: 'AWS Lambda',
        body: 'Stateless agent calls, predictor inference, LLM-as-judge, rationale clustering, replay-concordance, replay-counterfactual. Container-image deploys via ECR for the Python 3.12 research Lambda.',
      },
      {
        name: 'AWS EC2',
        body: '`t3.small` for the executor daemon (stateful, holds the IB Gateway connection), `t3.micro` for the dashboard, `c5.large` spot for batch (predictor training + backtester). Right-sized per workload — when `predictor_data_prep` OOMed on c5.large, the response was a pandas refactor (~1.1 GB → ~91 MB resident), not a bump to xlarge.',
      },
      {
        name: 'CloudFormation',
        body: 'Infrastructure-as-Code for Step Functions, Lambda functions, IAM roles, EventBridge rules. Drift detector compares CloudFormation stamps against live AWS state weekly.',
      },
    ],
  },
  {
    heading: 'Surfaces',
    entries: [
      {
        name: 'Astro (this site)',
        body: 'Static-site generator for the apex marketing surface — zero JS shipped by default, fast TTFB, build-time SEO. The harness identity benefits from a marketing surface that loads as instantly as the instrument it describes.',
      },
      {
        name: 'IBC (Interactive Brokers Gateway)',
        body: 'Paper-account broker connection on the executor host. Hard runtime check refuses to connect to non-paper accounts (account ID must start with "D") — defense against accidental live-account wiring.',
      },
    ],
  },
];

/**
 * Render a body string with single-backtick `code` spans → <code> elements
 * and plain text passing through untouched. Avoids pulling a full markdown
 * renderer for this single-page use case.
 */
function renderInline(body: string): string {
  const parts: string[] = [];
  let lastIndex = 0;
  const re = /`([^`]+)`/g;
  let match: RegExpExecArray | null = re.exec(body);
  while (match !== null) {
    if (match.index > lastIndex) {
      parts.push(escapeHtml(body.slice(lastIndex, match.index)));
    }
    parts.push(`<code>${escapeHtml(match[1])}</code>`);
    lastIndex = match.index + match[0].length;
    match = re.exec(body);
  }
  if (lastIndex < body.length) {
    parts.push(escapeHtml(body.slice(lastIndex)));
  }
  return parts.join('');
}

function escapeHtml(s: string): string {
  return s
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}
---

<Base
  title="Stack — Nous Ergon"
  description="Curated list of the non-default product choices in the Nous Ergon system. Commodity primitives (S3, EventBridge, IAM) omitted by design — the picks that explain a design decision are the picks worth listing."
>
  <section class="max-w-3xl mx-auto px-6 pt-16 pb-12">
    <h1 class="text-2xl md:text-3xl font-semibold text-zinc-100 mb-4">Stack</h1>
    <p class="text-sm md:text-base text-zinc-400 leading-relaxed">
      The non-default product choices in the system. Commodity primitives (S3,
      EventBridge, IAM) omitted by design — the picks that explain a design
      decision are the picks worth listing.
    </p>
  </section>

  <section class="max-w-3xl mx-auto px-6 pb-16 space-y-10">
    {
      sections.map((section) => (
        <div>
          <h2 class="text-xs font-semibold uppercase tracking-wider text-sky-400 mb-4">
            {section.heading}
          </h2>
          <ul class="space-y-4">
            {section.entries.map((entry) => (
              <li>
                <div class="text-sm md:text-base font-semibold text-zinc-100 mb-1">
                  {entry.name}
                </div>
                <p
                  class="text-sm text-zinc-400 leading-relaxed"
                  set:html={renderInline(entry.body)}
                />
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </section>
</Base>

<style>
  code {
    color: rgb(125 211 252); /* sky-300 */
    background: rgba(255, 255, 255, 0.04);
    padding: 0.1em 0.35em;
    border-radius: 3px;
    font-size: 0.875em;
  }
</style>
