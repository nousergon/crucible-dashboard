---
import Base from '../layouts/Base.astro';
import PhaseIndicator from '../components/PhaseIndicator.astro';

const pillars = [
  {
    title: 'Evaluation layer',
    body: 'Three-layer eval stack: typed metric records, a seven-tile weekly report card with honest N/A semantics, and an advisory Director agent gated through human-approved PRs. Calibrated LLM judges score every load-bearing agent decision.',
  },
  {
    title: 'Multi-agent research',
    body: 'Six sector teams, a portfolio decision agent, and a macro layer on LangGraph + Claude. Structured outputs, LLM-as-judge.',
  },
  {
    title: 'Statistical validation',
    body: 'Stacked ensemble of gradient-boosted and linear models predicting 21-day market-relative returns. Promotion is governed by leak-free cross-validation, deflated performance metrics, and multiplicity-aware screening — not point estimates.',
  },
  {
    title: 'Gated self-improvement',
    body: 'Weekly optimizers and a champion/challenger model zoo auto-tune and auto-promote — only through named statistical gates with observe modes, revert paths, and registries. The system improves itself; humans approve the consequential moves.',
  },
];

const proofPoints = [
  'Combinatorial purged cross-validation + deflated Sharpe (DSR/PSR) + BH-FDR multiplicity screening on every model promotion',
  'Model zoo with auto-promote, loud revert paths, and turnover-governed cutover — institutional champion/challenger governance',
  'Three-layer evaluation stack with honest N/A semantics and an advisory Director agent gated through human-approved PRs',
  'Uncertainty-penalized portfolio optimization with covariance shrinkage at 25-name scale',
  'Absence-driven artifact-freshness monitoring against a declarative SLA registry — a missing artifact is itself an alarm',
  'Units-suffix schema contracts with cross-repo consumer tests on the feature store',
  'All of the above at low tens of dollars per month of infrastructure',
];
---

<Base>
  <section class="max-w-3xl mx-auto px-6 pt-10 md:pt-12 pb-16 text-center">
    <h1 class="text-2xl md:text-[1.75rem] font-medium text-zinc-100 leading-snug tracking-tight mb-5 max-w-2xl mx-auto">
      A harness for rigorous AI/ML experiments in finance.
    </h1>
    <p class="text-sm md:text-base text-zinc-400 leading-relaxed max-w-xl mx-auto">
      An autonomous equity research-and-trading system &mdash; multi-agent
      research, ML prediction, risk-gated execution &mdash; instrumented
      end-to-end<sup
        ><a
          href="#en-1"
          id="en-1-ref"
          class="text-sky-400 hover:text-sky-300 ml-0.5 text-[10px] no-underline"
          aria-label="See endnote 1: what instrumented end-to-end means">[1]</a
        ></sup
      > and governed by a finance-specific evaluation layer.
    </p>
    <p class="text-sm md:text-base text-zinc-400 italic leading-relaxed max-w-xl mx-auto mt-3">
      Every experiment runs against a pre-committed acceptance bar.
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3 text-sm">
      <a
        href="https://live.nousergon.ai/"
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-md border border-white/15 px-4 py-2 text-zinc-100 hover:bg-white/5 transition"
      >
        Open the Dashboard &rarr;
      </a>
      <a
        href="/experiments"
        class="rounded-md border border-white/15 px-4 py-2 text-zinc-100 hover:bg-white/5 transition"
      >
        Experiment Register
      </a>
      <a
        href="https://github.com/cipher813/alpha-engine-evaluator"
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-md border border-white/15 px-4 py-2 text-zinc-100 hover:bg-white/5 transition"
      >
        Evaluator (MIT)
      </a>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-6 pb-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {
        pillars.map((p) => (
          <div class="rounded-lg border border-white/10 bg-white/[0.03] p-5">
            <div class="text-xs font-semibold uppercase tracking-wider text-sky-400 mb-2">
              {p.title}
            </div>
            <p class="text-sm text-zinc-300 leading-relaxed">{p.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-6 pb-16">
    <h2 class="text-xs font-semibold uppercase tracking-wider text-sky-400 mb-2 text-center">
      Institutional patterns at solo-operator cost
    </h2>
    <p class="text-sm text-zinc-400 leading-relaxed text-center mb-6 max-w-xl mx-auto">
      The machinery, not adjectives. Each of these is in production today:
    </p>
    <ul class="space-y-2.5 text-sm text-zinc-300 leading-relaxed list-disc list-outside pl-5 marker:text-sky-500/60">
      {proofPoints.map((p) => <li>{p}</li>)}
    </ul>
    <p class="text-sm text-zinc-400 leading-relaxed mt-6 text-center">
      How it fits together: <a href="/architecture" class="text-sky-400 hover:text-sky-300 transition">Architecture</a>
      &middot; the reusable pieces: <a href="/components" class="text-sky-400 hover:text-sky-300 transition">Components</a>
      &middot; what's being tested: <a href="/experiments" class="text-sky-400 hover:text-sky-300 transition">Experiments</a>
    </p>
  </section>

  <PhaseIndicator current="Reliability + Measurability" />

  <aside
    class="max-w-3xl mx-auto px-6 pt-6 pb-20 text-zinc-400"
    aria-label="Endnotes"
  >
    <div class="border-t border-white/10 pt-6">
      <h2 class="text-[11px] uppercase tracking-[0.2em] text-zinc-500 mb-4">
        Endnotes
      </h2>
      <ol class="space-y-3 text-[13px] leading-relaxed list-none counter-reset-[en]">
        <li id="en-1" class="flex gap-3">
          <span class="text-zinc-500 shrink-0 pt-0.5" aria-hidden="true">[1]</span>
          <div>
            <em class="text-zinc-300">Instrumented end-to-end</em> means every
            layer of the pipeline is observable and auditable:
            <ul class="mt-2 space-y-1.5 list-disc list-outside pl-5 marker:text-zinc-600">
              <li>
                <strong class="text-zinc-300">Decision artifacts</strong> &mdash; research-agent
                LLM calls capture prompt, response, tool calls, and structured metadata to
                <code>s3://alpha-engine-research/decision_artifacts/</code>, with LLM-as-judge
                rubric scores attached on every load-bearing agent type (sector quant, qual,
                peer-review, thesis-update, macro economist, CIO).
              </li>
              <li>
                <strong class="text-zinc-300">Cost telemetry</strong> &mdash; per-call cost
                tracked at LLM call time and aggregated to a weekly cost parquet.
              </li>
              <li>
                <strong class="text-zinc-300">Trade audit log</strong> &mdash; every order,
                fill, and exit decision recorded with per-trade <code>realized_pnl</code>
                and rationale where applicable; the audit trail that surfaced the
                <a class="text-sky-400 hover:text-sky-300 transition" href="/retros/01-pfe-short-sell/"
                  >PFE short-sell retro</a
                >.
              </li>
              <li>
                <strong class="text-zinc-300">Performance metrics</strong> &mdash; signal
                accuracy at 10d / 30d, predictor rolling 30d IC, NAV vs SPY daily returns,
                per-trade realized P&amp;L, daily portfolio-level attribution
                (position P&amp;L + interest + unattributed residual).
              </li>
              <li>
                <strong class="text-zinc-300">LangSmith tracing</strong> &mdash; trace ID +
                token counts on every production LLM call.
              </li>
              <li>
                <strong class="text-zinc-300">Parity replay</strong> &mdash; the backtester
                replays the morning-planner stage of historical runs as an observational diff
                against current code.
              </li>
            </ul>
            <a
              href="#en-1-ref"
              class="inline-block mt-3 text-zinc-500 hover:text-zinc-300 transition text-[12px]"
              aria-label="Back to reference"
            >
              &uarr; back
            </a>
          </div>
        </li>
      </ol>
    </div>
  </aside>
</Base>
