---
import Base from '../layouts/Base.astro';

/**
 * Public Experiment Register — the outward face of the internal experiment
 * registries. Discipline: only experiments that are REAL (running or closed
 * with results) appear here — never a speculative roadmap. Each entry
 * pre-commits its acceptance bar before the soak starts; results are
 * recorded whichever way they land. Negative results are published.
 */

type Status = 'running-observe' | 'running-cutover' | 'closed';

interface Experiment {
  title: string;
  module: string;
  family: 'Evaluation & infrastructure' | 'Research' | 'Models';
  hypothesis: string;
  bar: string;
  status: Status;
  statusNote: string;
  result: string;
}

const experiments: Experiment[] = [
  {
    title: 'Champion/challenger auto-promotion (model zoo)',
    module: 'Predictor',
    family: 'Evaluation & infrastructure',
    hypothesis:
      'Weekly challenger training with leak-free cross-validated selection can govern champion promotion autonomously — no noise-driven promotes, every promotion reversible with one command.',
    bar: 'At least 1–2 clean auto-promote rotations: a sane leaderboard ranking, a promotion alert carrying a working revert command, and any bad promote caught within the weekend window.',
    status: 'running-cutover',
    statusNote: 'Auto-promotion armed 2026-06-09; first live rotation 2026-06-13.',
    result: 'Pending.',
  },
  {
    title: 'Leak-free validation battery',
    module: 'Predictor',
    family: 'Evaluation & infrastructure',
    hypothesis:
      'The in-sample meta-ensemble information coefficient materially overstates skill; model promotion should gate on leak-free combinatorial purged cross-validation plus deflated performance metrics instead.',
    bar: 'Two to three weekly training runs producing stable leak-free measurements; the promotion gate then flips from the in-sample figure to the leak-free stack.',
    status: 'running-observe',
    statusNote: 'Leak-free measurement runs alongside every weekly training.',
    result:
      'Pending. Early readings confirm the in-sample figure is materially inflated relative to the leak-free measurement — the direction the hypothesis predicts.',
  },
  {
    title: 'Backtester input-quality gate',
    module: 'Backtester',
    family: 'Evaluation & infrastructure',
    hypothesis:
      'Degenerate signal inputs should fail loudly before compute is spent, rather than silently producing a no-op parameter sweep.',
    bar: 'At least 1–2 weekly runs with correct verdicts on healthy inputs (zero false positives); enforcement then flips from observe to blocking.',
    status: 'running-observe',
    statusNote: 'Verdicts computed on every weekly run; enforcement off during observation.',
    result: 'Pending.',
  },
  {
    title: 'De-blended CIO orchestration',
    module: 'Research',
    family: 'Research',
    hypothesis:
      'Separating the quantitative score blend from the CIO agent’s qualitative judgment — so the agent judges rather than re-blends — improves stock-selection quality.',
    bar: 'Over at least 2–3 weekly research cycles, the sector-neutral information coefficient of the combined score must beat the pooled baseline, and CIO selection skill must not regress.',
    status: 'running-observe',
    statusNote: 'Enabled 2026-06-08; reversible by flag, inert if reverted.',
    result: 'Pending.',
  },
];

const STATUS_LABEL: Record<Status, string> = {
  'running-observe': 'Running — observe',
  'running-cutover': 'Running — cutover',
  closed: 'Closed',
};

const STATUS_STYLE: Record<Status, string> = {
  'running-observe': 'bg-sky-950/40 border-sky-500/50 text-sky-300',
  'running-cutover': 'bg-amber-950/40 border-amber-500/50 text-amber-300',
  closed: 'bg-emerald-950/40 border-emerald-700/50 text-emerald-300',
};

const families = [
  'Evaluation & infrastructure',
  'Research',
  'Models',
] as const;
---

<Base
  title="Experiments — Nous Ergon"
  description="The public experiment register: each entry is a hypothesis with a pre-committed acceptance bar, a status, and a recorded result. Negative results are published."
>
  <section class="max-w-3xl mx-auto px-6 pt-12 pb-10">
    <h1 class="text-2xl md:text-3xl font-semibold text-zinc-100 mb-4">Experiments</h1>
    <p class="text-sm md:text-base text-zinc-400 leading-relaxed mb-4">
      The register of experiments running on the harness. Each entry is a
      falsifiable hypothesis with an acceptance bar committed
      <em>before</em> the trial starts, a status, and a recorded result &mdash;
      whichever way it lands. Only real experiments appear here: running, or
      closed with results. Negative results are published; they are the
      highest-credibility entries a register can hold.
    </p>
    <p class="text-sm md:text-base text-zinc-400 leading-relaxed">
      Alpha versus the S&amp;P 500 is measured continuously as a background
      metric, but it is not a featured experiment today &mdash; the evaluation
      and infrastructure arcs come first. It re-enters the register as a
      featured experiment after those have been trialed, and graduates to a
      public readout when it clears its pre-committed bar.
    </p>
  </section>

  <section class="max-w-4xl mx-auto px-6 pb-16 space-y-12">
    {
      families.map((family) => {
        const group = experiments.filter((e) => e.family === family);
        if (group.length === 0) {
          return (
            <div>
              <h2 class="text-xs font-semibold uppercase tracking-wider text-sky-400 mb-4">
                {family}
              </h2>
              <p class="text-sm text-zinc-500">
                No experiments registered in this group yet.
              </p>
            </div>
          );
        }
        return (
          <div>
            <h2 class="text-xs font-semibold uppercase tracking-wider text-sky-400 mb-4">
              {family}
            </h2>
            <div class="space-y-4">
              {group.map((e) => (
                <article class="rounded-lg border border-white/10 bg-white/[0.03] p-5">
                  <div class="flex flex-wrap items-center gap-3 mb-3">
                    <h3 class="text-sm md:text-base font-semibold text-zinc-100">
                      {e.title}
                    </h3>
                    <span
                      class={`text-[10px] font-semibold uppercase tracking-wider rounded-full border px-2.5 py-0.5 ${STATUS_STYLE[e.status]}`}
                    >
                      {STATUS_LABEL[e.status]}
                    </span>
                    <span class="text-[11px] uppercase tracking-wider text-zinc-500">
                      {e.module}
                    </span>
                  </div>
                  <dl class="space-y-2.5 text-sm leading-relaxed">
                    <div>
                      <dt class="inline font-semibold text-zinc-300">Hypothesis. </dt>
                      <dd class="inline text-zinc-400">{e.hypothesis}</dd>
                    </div>
                    <div>
                      <dt class="inline font-semibold text-zinc-300">Pre-committed bar. </dt>
                      <dd class="inline text-zinc-400">{e.bar}</dd>
                    </div>
                    <div>
                      <dt class="inline font-semibold text-zinc-300">Status. </dt>
                      <dd class="inline text-zinc-400">{e.statusNote}</dd>
                    </div>
                    <div>
                      <dt class="inline font-semibold text-zinc-300">Result. </dt>
                      <dd class="inline text-zinc-400">{e.result}</dd>
                    </div>
                  </dl>
                </article>
              ))}
            </div>
          </div>
        );
      })
    }

    <div class="border-t border-white/10 pt-8">
      <p class="text-sm text-zinc-500 leading-relaxed">
        Closed experiments accumulate here as trials conclude &mdash; including
        the ones that fail their bar. Methodology writeups land on the
        <a class="text-sky-400 hover:text-sky-300 transition" href="/blog/">blog</a>;
        operational incidents get full postmortems in
        <a class="text-sky-400 hover:text-sky-300 transition" href="/retros/">Retros</a>.
      </p>
    </div>
  </section>
</Base>
