---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  /**
   * Optional JSON-LD structured data injected into <head>. The layout
   * defaults to a WebSite + Organization graph for the apex site; pages
   * that need page-specific schema (e.g. Article, AboutPage, BreadcrumbList)
   * can pass their own object to override.
   */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const SITE_URL = 'https://nousergon.ai';

const {
  title = 'Nous Ergon — Experimentation harness for systematic equity strategies',
  description = 'An experimentation harness for systematic equity strategies. Multi-agent research, machine-learning prediction, risk-gated execution, instrumented end-to-end from signal to P&L. The first experiment is alpha capture against the S&P 500.',
  jsonLd,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, SITE_URL).toString();

const defaultJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${SITE_URL}#organization`,
      name: 'Nous Ergon',
      url: SITE_URL,
      founder: {
        '@type': 'Person',
        name: 'Brian McMahon',
        url: 'https://www.linkedin.com/in/brian-c-mcmahon/',
        sameAs: ['https://github.com/cipher813'],
      },
    },
    {
      '@type': 'WebSite',
      '@id': `${SITE_URL}#website`,
      url: SITE_URL,
      name: 'Nous Ergon',
      description,
      publisher: { '@id': `${SITE_URL}#organization` },
      inLanguage: 'en-US',
    },
  ],
};

const resolvedJsonLd = jsonLd ?? defaultJsonLd;
---

<!doctype html>
<html lang="en" class="bg-black text-zinc-200 antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Nous Ergon" />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
    <script
      type="application/ld+json"
      set:html={JSON.stringify(resolvedJsonLd)}
    />
  </head>
  <body class="min-h-screen flex flex-col font-sans">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:rounded focus:bg-sky-500 focus:px-3 focus:py-2 focus:text-sm focus:text-white"
    >
      Skip to main content
    </a>

    <header class="border-b border-white/10">
      <nav
        class="max-w-5xl mx-auto px-6 py-5 flex items-center justify-between"
        aria-label="Primary"
      >
        <a
          href="/"
          class="text-base font-semibold tracking-tight text-zinc-100 hover:text-white transition"
        >
          Nous Ergon
        </a>
        <div class="flex items-center gap-5 text-sm text-zinc-400">
          <a href="/about" class="hover:text-zinc-100 transition">About</a>
          <a href="/architecture" class="hover:text-zinc-100 transition">Architecture</a>
          <a href="/stack" class="hover:text-zinc-100 transition">Stack</a>
          <a href="/retros/" class="hover:text-zinc-100 transition">Retros</a>
          <a href="https://live.nousergon.ai/" class="hover:text-zinc-100 transition">
            Live console &rarr;
          </a>
        </div>
      </nav>
    </header>

    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-white/10 mt-24">
      <div
        class="max-w-5xl mx-auto px-6 py-8 text-xs text-zinc-500 flex flex-col md:flex-row md:items-center md:justify-between gap-3"
      >
        <div>
          Built by
          <a
            href="https://www.linkedin.com/in/brian-c-mcmahon/"
            class="text-zinc-400 hover:text-zinc-100 transition"
          >
            Brian McMahon
          </a>
          &middot;
          <a
            href="https://github.com/cipher813"
            class="text-zinc-400 hover:text-zinc-100 transition"
          >
            GitHub
          </a>
          &middot;
          <a
            href="mailto:brian@nousergon.ai"
            class="text-zinc-400 hover:text-zinc-100 transition"
          >
            brian@nousergon.ai
          </a>
        </div>
        <div class="text-zinc-600">&nu;&omicron;&upsilon;&sigmaf; &epsilon;&rho;&gamma;&omicron;&nu;</div>
      </div>
    </footer>
  </body>
</html>
