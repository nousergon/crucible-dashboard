---
/**
 * Phase indicator — surfaces the system's current engineering phase.
 *
 * Ported from `components/phase_indicator.py` so the marketing home page
 * shows the same "where we are now / what we're optimizing for" context
 * as the Streamlit live console. Single source of truth lives here for
 * the marketing surface; the Streamlit version is the canonical for the
 * live console.
 */

interface Props {
  current?: string;
}

const { current = 'Reliability + Measurability' } = Astro.props;

interface Phase {
  name: string;
  kpi: string;
  description: string[];
}

const PHASES: Phase[] = [
  {
    name: 'Completeness',
    kpi: 'Coverage',
    description: [
      'Seven modules wired end-to-end via S3 — data, research, prediction, execution, backtesting, evaluation, dashboard.',
      'Multi-agent research, stacked meta-ensemble, risk-gated executor, weekly backtester.',
      'Three Step Functions running unattended (Saturday weekly + weekday morning + EOD).',
    ],
  },
  {
    name: 'Reliability + Measurability',
    kpi: 'Uptime + Coverage',
    description: [
      'Step Functions reliable end-to-end with drift detection and runtime trend alarms.',
      'Every decision point measurable — agent calls, predictor verdicts, fills, P&L attribution, risk events.',
      'Closed feedback loop — backtester writing four optimized configs to S3 weekly.',
    ],
  },
  {
    name: 'Performance (paper)',
    kpi: 'Alpha vs SPY',
    description: [
      'Runs featured experiments against pre-committed bars on the Phase-2 substrate.',
      'Broader feature breadth in inference (current 21 features → ~50-feature ArcticDB store).',
      'Gated on ≥99% SF success rate over 8 weeks + transparency-inventory complete.',
    ],
  },
  {
    name: 'Performance (live)',
    kpi: 'NAV',
    description: [
      'Paper → live capital with progressive sizing.',
      'Portfolio-level risk overlays beyond per-position gates.',
      'Gated on sustained positive alpha vs SPY over a 12-week Phase 3 window.',
    ],
  },
];

const currentIndex = PHASES.findIndex((p) => p.name === current);

type Status = 'complete' | 'current' | 'upcoming';

function statusFor(i: number): Status {
  if (i < currentIndex) return 'complete';
  if (i === currentIndex) return 'current';
  return 'upcoming';
}

const STATUS_STYLES: Record<Status, { pill: string; chip: string; border: string; chipText: string }> = {
  complete: {
    pill: 'bg-emerald-950/40 border-emerald-700/50',
    chip: 'text-emerald-400',
    border: 'border-emerald-700/50',
    chipText: 'text-emerald-400',
  },
  current: {
    pill: 'bg-sky-950/40 border-sky-500/50',
    chip: 'text-sky-400',
    border: 'border-sky-500/50',
    chipText: 'text-sky-400',
  },
  upcoming: {
    pill: 'bg-white/[0.02] border-white/10',
    chip: 'text-zinc-500',
    border: 'border-white/10',
    chipText: 'text-zinc-500',
  },
};

const STATUS_ICON: Record<Status, string> = {
  complete: '✓',
  current: '▶',
  upcoming: '·',
};
---

<section class="max-w-5xl mx-auto px-6 pb-20" aria-label="Engineering phases">
  <div class="text-center mb-6">
    <p class="text-[11px] uppercase tracking-[0.2em] text-zinc-500 mb-2">
      Current phase
    </p>
    <p class="text-sm text-zinc-400 italic max-w-2xl mx-auto">
      Every aspect of the system reliable and measurable &mdash; every
      experiment decided on data, not vibes.
    </p>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
    {
      PHASES.map((phase, i) => {
        const status = statusFor(i);
        const s = STATUS_STYLES[status];
        return (
          <div class={`rounded-md border ${s.pill} p-3 text-center`}>
            <div class={`text-[10px] font-semibold uppercase tracking-wider ${s.chip}`}>
              Phase {i + 1} {STATUS_ICON[status]}
            </div>
            <div class="text-[13px] font-semibold text-zinc-100 mt-1 leading-tight">
              {phase.name}
            </div>
            <div class="text-[11px] text-zinc-500 mt-1">KPI: {phase.kpi}</div>
          </div>
        );
      })
    }
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-3 mt-4">
    {
      PHASES.map((phase, i) => {
        const status = statusFor(i);
        const s = STATUS_STYLES[status];
        return (
          <div class={`rounded-md border ${s.border} bg-white/[0.02] p-3.5`}>
            <div class={`text-[11px] font-semibold uppercase tracking-wider ${s.chipText} mb-2`}>
              Phase {i + 1} &middot; {phase.name}
            </div>
            <ul class="text-[12px] text-zinc-400 leading-relaxed space-y-1 pl-4 list-disc">
              {phase.description.map((b) => (
                <li>{b}</li>
              ))}
            </ul>
          </div>
        );
      })
    }
  </div>
</section>
