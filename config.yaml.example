# ─────────────────────────────────────────────────────────────────────────────
# DESCRIPTIVE / DOCUMENTATION ONLY
#
# Production reads the live config from config.yaml on the dashboard EC2
# instance (gitignored, lives in ~/alpha-engine-dashboard/config.yaml on
# the host that runs dashboard.service — the private console at
# console.nousergon.ai). The live config is NOT in alpha-engine-config
# (unlike most other modules) — it's per-instance state on the EC2 host.
#
# Edits to this .example file affect ONLY:
#   1. New-environment bootstrap (copies this template to config.yaml), and
#   2. Public-repo schema documentation for the dashboard config surface.
#
# Edits here have ZERO effect on the live dashboard. To change a runtime
# value, SSH to the dashboard host and edit ~/alpha-engine-dashboard/
# config.yaml directly, then restart dashboard.service.
# ─────────────────────────────────────────────────────────────────────────────

s3:
  research_bucket: alpha-engine-research
  # Live trade artifacts (trades/, health/eod_reconcile.json, uptime/) migrated
  # to the research bucket 2026-04; alpha-engine-executor is legacy/stale.
  trades_bucket: alpha-engine-research

paths:
  signals: signals/{date}/signals.json
  cio_decisions: archive/agent_runs/{date}/cio.json
  research_db: research.db
  trades_full: trades/trades_full.csv
  eod_pnl: trades/eod_pnl.csv
  backtest_prefix: backtest/
  scoring_weights: config/scoring_weights.json
  scoring_weights_history_prefix: config/scoring_weights_history/

cache_ttl:
  signals: 900      # 15 min
  trades: 900       # 15 min
  research: 3600    # 1 hour
  backtest: 3600    # 1 hour

drawdown_circuit_breaker: -0.08  # -8%

risk_limits:
  max_sector_pct: 0.25

# Display thresholds — tune to match current system targets.
# These drive status badges, chart reference lines, and gating UI copy;
# they do not affect trading behavior.
thresholds:
  veto_confidence: 0.65       # Predictor confidence to trigger a DOWN veto
  model_healthy: 0.52         # 🟢 Healthy: 30d rolling hit rate ≥ this
  model_degraded: 0.48        # 🟡 Degraded: 30d rolling hit rate ≥ this (below healthy)
  accuracy_baseline: 0.50     # Coin-flip baseline for accuracy charts
  accuracy_outperform: 0.55   # Shaded "outperform" band start for accuracy charts
  hhi_diversified: 0.15       # HHI < this → "Diversified"
  hhi_concentrated: 0.25      # HHI ≥ this → "Concentrated" (else "Moderate")
  sharpe_min_rows: 30         # Min days required to compute Sharpe ratio
  population_target: 25       # Research target_size — population above this has 0 open slots
  entrant_conviction_bar: 60  # De-facto CIO conviction bar a fresh name clears to enter (reference line)
