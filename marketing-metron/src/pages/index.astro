---
import metronLogo from '../assets/nous-ergon-metron-logo.webp';
import '../styles/global.css';

const SITE_URL = 'https://metron.nousergon.ai';
const title = 'Metron — portfolio analytics · Nous Ergon';
const description =
  'Metron is portfolio analytics from Nous Ergon: positions, performance, income, tax, and concentration across your brokers, accounts, and currencies. Read-only, no ads, no trackers. Join the private beta.';

// Cloudflare Web Analytics beacon token (privacy-first, no cookies). Injected at
// build time via PUBLIC_CF_ANALYTICS_TOKEN; the beacon is omitted when unset so a
// missing token never ships a broken script. See README for provisioning.
const analyticsToken = import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN;

// The descriptive core the private beta delivers today (broker-sourced — no licensed
// market-data feed required). Every item is something the product computes now.
const features = [
  {
    name: 'Positions & holdings',
    body: 'Every position across brokers, accounts, and currencies, consolidated into one view.',
  },
  {
    name: 'Performance',
    body: 'Money-weighted return (XIRR) and forward time-weighted return from your own NAV history.',
  },
  {
    name: 'Income',
    body: 'Dividends and interest by year, with yield-on-cost on what you actually hold.',
  },
  {
    name: 'Tax',
    body: 'Cost basis, holding-period term, and realized / unrealized gains per lot — across accounts.',
  },
  {
    name: 'Concentration',
    body: 'Position and sector weights, so you can see where the portfolio is actually exposed.',
  },
  {
    name: 'Macro context',
    body: 'Public-domain macro series (rates, the yield curve, volatility) alongside your book.',
  },
];

// On the roadmap for the paid tier — stated as future, not as a current capability.
const proRoadmap = [
  'Benchmark-relative return vs the S&P 500',
  'Factor risk and tracking error',
  'Sector attribution',
  'Historical scenarios and stress views',
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://nousergon.ai#organization',
      name: 'Nous Ergon',
      url: 'https://nousergon.ai',
    },
    {
      '@type': 'WebSite',
      '@id': `${SITE_URL}#website`,
      url: SITE_URL,
      name: 'Metron',
      description,
      publisher: { '@id': 'https://nousergon.ai#organization' },
      inLanguage: 'en-US',
    },
  ],
};
---

<!doctype html>
<html lang="en" class="bg-black text-zinc-200 antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="canonical" href={SITE_URL} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Metron · Nous Ergon" />
    <meta property="og:url" content={SITE_URL} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    {
      analyticsToken && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={JSON.stringify({ token: analyticsToken })}
        />
      )
    }
  </head>
  <body class="min-h-screen flex flex-col font-sans">
    <main class="flex-1">
      <!-- Hero -->
      <section class="px-6 pt-16 pb-12 md:pt-24 md:pb-16">
        <div class="max-w-2xl mx-auto flex flex-col items-center text-center">
          <!-- Lossless asset via plain <img> — masthead assets must reach the
               browser byte-exact (lossy re-encode bands dark gradients). -->
          <img
            src={metronLogo.src}
            width={metronLogo.width}
            height={metronLogo.height}
            alt="Nous Ergon — Metron"
            class="w-full max-w-[340px] h-auto"
            loading="eager"
            decoding="sync"
            fetchpriority="high"
          />
          <h1 class="mt-8 text-2xl md:text-4xl font-semibold tracking-tight text-zinc-100 text-balance">
            See your whole portfolio clearly.
          </h1>
          <p class="mt-5 text-sm md:text-base text-zinc-400 leading-relaxed max-w-xl text-pretty">
            Metron consolidates positions, performance, income, and tax across your brokers, accounts,
            and currencies into one honest view. Read-only. No ads, no trackers, no advice.
          </p>

          <!-- Waitlist capture -->
          <form
            id="waitlist-form"
            class="mt-8 w-full max-w-md flex flex-col sm:flex-row gap-2"
            novalidate
          >
            <label for="email" class="sr-only">Email address</label>
            <input
              id="email"
              name="email"
              type="email"
              required
              autocomplete="email"
              placeholder="you@example.com"
              class="flex-1 rounded-md border border-white/15 bg-white/5 px-4 py-2.5 text-sm text-zinc-100 placeholder:text-zinc-500 outline-none transition focus:border-sky-400/70 focus:bg-white/[0.07]"
            />
            <!-- Honeypot: bots fill this; humans never see it. Submissions with it set are dropped. -->
            <input
              type="text"
              name="website"
              tabindex="-1"
              autocomplete="off"
              class="hidden"
              aria-hidden="true"
            />
            <button
              type="submit"
              class="shrink-0 rounded-md bg-sky-500 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-sky-400 disabled:opacity-50"
            >
              Join the beta
            </button>
          </form>
          <p id="waitlist-msg" class="mt-3 text-xs min-h-[1rem]" role="status" aria-live="polite"></p>
          <p class="mt-1 text-[11px] text-zinc-500">
            A private beta. We email you when there's a spot — nothing else.
          </p>
        </div>
      </section>

      <!-- What the beta delivers -->
      <section class="px-6 py-12 border-t border-white/10">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-400 text-center">
            In the beta
          </h2>
          <div class="mt-8 grid gap-px sm:grid-cols-2 lg:grid-cols-3 bg-white/10 rounded-lg overflow-hidden border border-white/10">
            {
              features.map((f) => (
                <div class="bg-black p-5">
                  <h3 class="text-sm font-semibold text-zinc-100">{f.name}</h3>
                  <p class="mt-1.5 text-xs text-zinc-400 leading-relaxed">{f.body}</p>
                </div>
              ))
            }
          </div>
          <p class="mt-6 text-center text-xs text-zinc-500 max-w-xl mx-auto">
            Import a CSV or OFX file, or connect a brokerage — Metron values your holdings from your
            broker's own data. Multi-broker, multi-account, multi-currency from day one.
          </p>
        </div>
      </section>

      <!-- Trust posture -->
      <section class="px-6 py-10 border-t border-white/10">
        <div class="max-w-4xl mx-auto flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-xs text-zinc-400">
          <span>Read-only — Metron never trades</span>
          <span class="text-zinc-700" aria-hidden="true">·</span>
          <span>No ads, no third-party trackers</span>
          <span class="text-zinc-700" aria-hidden="true">·</span>
          <span>No advice — analytics, not recommendations</span>
          <span class="text-zinc-700" aria-hidden="true">·</span>
          <span>Your data stays yours</span>
        </div>
      </section>

      <!-- Pro roadmap (clearly future) -->
      <section class="px-6 py-12 border-t border-white/10">
        <div class="max-w-4xl mx-auto text-center">
          <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500">
            On the roadmap for Pro
          </h2>
          <p class="mt-3 text-sm text-zinc-400 max-w-xl mx-auto leading-relaxed">
            A paid tier will add benchmark and factor analytics on top of the core, powered by a
            licensed market-data feed:
          </p>
          <ul class="mt-5 flex flex-wrap items-center justify-center gap-2 max-w-2xl mx-auto">
            {
              proRoadmap.map((p) => (
                <li class="rounded-full border border-white/10 px-3 py-1 text-xs text-zinc-400">
                  {p}
                </li>
              ))
            }
          </ul>
        </div>
      </section>
    </main>

    <footer class="border-t border-white/10">
      <div
        class="max-w-5xl mx-auto px-6 py-8 text-xs text-zinc-500 flex flex-col md:flex-row md:items-center md:justify-between gap-3"
      >
        <div>
          <a href="https://nousergon.ai/" class="text-zinc-400 hover:text-zinc-100 transition">
            Nous Ergon
          </a>
          &mdash; an applied AI lab for financial markets
          &middot;
          <a href="mailto:nous@nousergon.ai" class="text-zinc-400 hover:text-zinc-100 transition">
            nous@nousergon.ai
          </a>
        </div>
        <div class="text-zinc-600">&nu;&omicron;&upsilon;&sigmaf; &epsilon;&rho;&gamma;&omicron;&nu;</div>
      </div>
    </footer>

    <script>
      // Progressive enhancement: post the waitlist signup to the Pages Function and
      // swap inline status copy. The form is a normal POST target, so a no-JS submit
      // still reaches /api/waitlist (which returns JSON either way).
      const form = document.getElementById('waitlist-form') as HTMLFormElement | null;
      const msg = document.getElementById('waitlist-msg');
      const button = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;

      function setMsg(text: string, ok: boolean) {
        if (!msg) return;
        msg.textContent = text;
        msg.className = `mt-3 text-xs min-h-[1rem] ${ok ? 'text-emerald-400' : 'text-rose-400'}`;
      }

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const data = new FormData(form);
        const email = String(data.get('email') ?? '').trim();
        if (!email || !email.includes('@')) {
          setMsg('Please enter a valid email address.', false);
          return;
        }
        if (button) button.disabled = true;
        setMsg('', true);
        try {
          const res = await fetch('/api/waitlist', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, website: data.get('website') ?? '' }),
          });
          if (res.ok) {
            form.reset();
            setMsg("You're on the list. We'll be in touch.", true);
          } else {
            const body = (await res.json().catch(() => ({}))) as { error?: string };
            setMsg(body.error ?? 'Something went wrong — please try again.', false);
            if (button) button.disabled = false;
          }
        } catch {
          setMsg('Network error — please try again.', false);
          if (button) button.disabled = false;
        }
      });
    </script>
  </body>
</html>
