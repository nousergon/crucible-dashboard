---
import Base from '../layouts/Base.astro';
---

<Base
  title="Founder — Nous Ergon"
  description="Brian McMahon founded Nous Ergon, an applied AI lab, in March 2026."
>
  <section class="max-w-3xl mx-auto px-6 pt-16 pb-12">
    <h1 class="text-2xl md:text-3xl font-semibold text-zinc-100 mb-2">Brian McMahon</h1>
    <p class="text-sm text-zinc-500 mb-8">Founder</p>

    <p class="text-sm md:text-base text-zinc-300 leading-relaxed mb-4">
      Brian founded Nous Ergon in March 2026 to build agentic systems against
      problems with measurable, continuously verifiable outcomes. He works at
      the intersection of software engineering, machine learning, and markets,
      with AI-augmented engineering at the core of the lab's method.
    </p>
    <p class="text-sm md:text-base text-zinc-300 leading-relaxed mb-8">
      The lab's flagship work is <a class="text-sky-400 hover:text-sky-300 transition" href="https://crucible.nousergon.ai/">Crucible</a>,
      a harness for rigorous AI/ML experiments in finance, running live.
    </p>

    <h2 class="text-xs font-semibold uppercase tracking-wider text-sky-400 mb-3">Links</h2>
    <ul class="text-sm md:text-base text-zinc-300 space-y-1">
      <li><a class="text-sky-400 hover:text-sky-300 transition" href="https://www.linkedin.com/in/brian-c-mcmahon/">LinkedIn</a></li>
      <li><a class="text-sky-400 hover:text-sky-300 transition" href="https://github.com/cipher813">GitHub</a></li>
      <li><a class="text-sky-400 hover:text-sky-300 transition" href="mailto:nous@nousergon.ai">nous@nousergon.ai</a></li>
    </ul>
  </section>
</Base>
