---
import Base from '../layouts/Base.astro';

// The apex is a thin category directory (Brian, 2026-07-02): one card per
// category with a click-through to the category/product surface. Product-level
// detail, statuses, and waitlists live on the destination pages — an interested
// finance user gets pointed at finance.nousergon.ai directly, a fitness user at
// vires.nousergon.ai; the apex just routes. Nothing here is labeled "Live":
// nothing is monetized yet.
const categories = [
  {
    name: 'Finance',
    href: 'https://finance.nousergon.ai/',
    body: 'Portfolio analytics, an experiment harness for AI/ML research in live markets, and a deterministic tax engine.',
    lineup: 'Metron · Crucible · Telos',
    note: 'In development — Metron beta waitlist open',
    cta: 'Explore finance →',
  },
  {
    name: 'Fitness',
    href: 'https://vires.nousergon.ai/',
    body: 'Strength training with an adaptive AI coach — log lifts, build routines, train to your goals.',
    lineup: 'Vires',
    note: 'In development — beta waitlist open',
    cta: 'Explore Vires →',
  },
  {
    name: 'Developer tools',
    href: 'https://github.com/nousergon',
    body: "Open-source infrastructure from the lab: AI-assistant memory, shared service primitives, pipeline observability, and an automated daily news brief.",
    lineup: 'mnemon · krepis · flow-doctor · morning-signal',
    note: 'Open source',
    cta: 'Nous Ergon on GitHub →',
  },
];
---

<Base>
  <section class="max-w-3xl mx-auto px-6 pt-10 md:pt-12 pb-14 text-center">
    <h1 class="text-2xl md:text-[1.75rem] font-medium text-zinc-100 leading-snug tracking-tight mb-5 max-w-2xl mx-auto">
      An applied AI lab.
    </h1>
    <p class="text-sm md:text-base text-zinc-400 leading-relaxed max-w-xl mx-auto">
      Nous Ergon &mdash; <em>intelligence at work</em>. We build agentic
      systems against problems with measurable, continuously verifiable
      outcomes.
    </p>
  </section>

  <section class="max-w-3xl mx-auto px-6 pb-20">
    <div class="grid grid-cols-1 gap-4">
      {
        categories.map((c) => (
          <a
            href={c.href}
            target="_blank"
            rel="noopener noreferrer"
            class="block rounded-lg border border-white/10 bg-white/[0.03] p-6 transition hover:bg-white/[0.05] hover:border-sky-400/30"
          >
            <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-2">
              <span class="text-base font-semibold text-zinc-100 tracking-wide uppercase">
                {c.name}
              </span>
              <span class="text-xs text-zinc-500">{c.lineup}</span>
              <span class="ml-auto text-[10px] font-semibold uppercase tracking-wider text-zinc-500">
                {c.note}
              </span>
            </div>
            <p class="text-sm text-zinc-300 leading-relaxed mb-3">{c.body}</p>
            <span class="text-sm text-sky-400">{c.cta}</span>
          </a>
        ))
      }
    </div>
  </section>
</Base>
