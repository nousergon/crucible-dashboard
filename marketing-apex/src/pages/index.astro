---
import Base from '../layouts/Base.astro';

// The apex is a thin category router (Brian, 2026-07-02): three buttons side by
// side, each with a short category summary up top and just the product names —
// all detail, statuses, and waitlists live on the destination pages. An
// interested finance user gets pointed at finance.nousergon.ai directly, a
// fitness user at vires.nousergon.ai; the apex just routes. Nothing here is
// labeled "Live": nothing is monetized yet.
const categories = [
  {
    name: 'Finance',
    href: 'https://finance.nousergon.ai/',
    summary: 'Portfolio analytics, market research systems, and tax software.',
    products: ['Metron', 'Crucible', 'Telos'],
    cta: 'Explore finance →',
  },
  {
    name: 'Fitness',
    href: 'https://vires.nousergon.ai/',
    summary: 'Strength training with an adaptive AI coach.',
    products: ['Vires'],
    cta: 'Explore fitness →',
  },
  {
    name: 'Developer tools',
    href: 'https://github.com/nousergon',
    summary: 'Open-source infrastructure from the lab.',
    products: ['mnemon', 'krepis', 'flow-doctor', 'morning-signal'],
    cta: 'View on GitHub →',
  },
];
---

<Base>
  <section class="max-w-3xl mx-auto px-6 pt-10 md:pt-12 pb-14 text-center">
    <h1 class="text-2xl md:text-[1.75rem] font-medium text-zinc-100 leading-snug tracking-tight mb-5 max-w-2xl mx-auto">
      An applied AI lab.
    </h1>
    <p class="text-sm md:text-base text-zinc-400 leading-relaxed max-w-xl mx-auto">
      Nous Ergon &mdash; <em>intelligence at work</em>. We build agentic
      systems against problems with measurable, continuously verifiable
      outcomes.
    </p>
  </section>

  <section class="max-w-5xl mx-auto px-6 pb-20">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {
        categories.map((c) => (
          <a
            href={c.href}
            target="_blank"
            rel="noopener noreferrer"
            class="flex flex-col rounded-lg border border-white/10 bg-white/[0.03] p-6 text-center transition hover:bg-white/[0.05] hover:border-sky-400/30"
          >
            <span class="text-base font-semibold text-zinc-100 tracking-wide uppercase">
              {c.name}
            </span>
            <p class="mt-2 text-xs text-zinc-400 leading-relaxed">{c.summary}</p>
            <ul class="mt-4 mb-5 space-y-1.5">
              {c.products.map((p) => (
                <li class="text-sm text-zinc-200">{p}</li>
              ))}
            </ul>
            <span class="mt-auto text-sm text-sky-400">{c.cta}</span>
          </a>
        ))
      }
    </div>
  </section>
</Base>
