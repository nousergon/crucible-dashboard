---
import '../styles/global.css';
import nousErgonViresLogo from '../assets/nous-ergon-vires-logo.webp';

const SITE_URL = 'https://fitness.nousergon.ai';
const title = 'Vires — strength training that adapts · Nous Ergon';
const description =
  'Vires is a strength-training app from Nous Ergon: log workouts, build routines, find any exercise with hybrid search, and train with an AI coach that plans around your goals. Join the private beta.';

// Cloudflare Web Analytics beacon token (privacy-first, no cookies). Injected at
// build time via PUBLIC_CF_ANALYTICS_TOKEN; the beacon is omitted when unset so a
// missing token never ships a broken script. See README for provisioning.
const analyticsToken = import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN;

// What the private beta delivers today. Every item is something the product does now —
// claims-disciplined, same rule as the Metron landing.
const features = [
  {
    name: 'Log workouts',
    body: 'Sets × reps × weight with warm-up flags, an inline rest countdown, and a hold timer for isometric moves.',
  },
  {
    name: 'Routines',
    body: 'Reusable templates that pre-fill your session — and what you lifted last time carries forward.',
  },
  {
    name: 'Find any exercise',
    body: 'Hybrid keyword + semantic search: type "RDL" or describe the movement, and it finds the lift.',
  },
  {
    name: 'AI coach',
    body: 'Plans around your objectives, watches accumulated fatigue, and reschedules when you miss a session.',
  },
  {
    name: 'Beyond the barbell',
    body: 'Log runs, rucks, and other cross-training — rucks get load- and grade-adjusted effort, and the coach sees it all.',
  },
  {
    name: 'Installable app',
    body: 'Mobile-first PWA — add it to your home screen and it works like a native app.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://nousergon.ai#organization',
      name: 'Nous Ergon',
      url: 'https://nousergon.ai',
    },
    {
      '@type': 'WebSite',
      '@id': `${SITE_URL}#website`,
      url: SITE_URL,
      name: 'Vires',
      description,
      publisher: { '@id': 'https://nousergon.ai#organization' },
      inLanguage: 'en-US',
    },
  ],
};
---

<!doctype html>
<html lang="en" class="bg-black text-zinc-200 antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="canonical" href={SITE_URL} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Vires · Nous Ergon" />
    <meta property="og:url" content={SITE_URL} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    {
      analyticsToken && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={JSON.stringify({ token: analyticsToken })}
        />
      )
    }
  </head>
  <body class="min-h-screen flex flex-col font-sans">
    <main class="flex-1">
      <!-- Hero -->
      <section class="px-6 pt-16 pb-12 md:pt-24 md:pb-16">
        <div class="max-w-2xl mx-auto flex flex-col items-center text-center">
          <div class="flex flex-col items-center gap-2">
            <!-- Plain <img> on the lossless asset: Astro's <Image> lossy re-encode
                 shifts the logo's near-black halo off true #000 against the
                 bg-black page (same fix as the apex site's masthead). -->
            <img
              src={nousErgonViresLogo.src}
              width={nousErgonViresLogo.width}
              height={nousErgonViresLogo.height}
              alt="Nous Ergon Vires"
              class="w-full max-w-[320px] h-auto"
              loading="eager"
              decoding="sync"
              fetchpriority="high"
            />
            <span class="text-[12px] tracking-[0.14em] text-zinc-500 italic">
              vires acquirit eundo &mdash; it gathers strength as it goes
            </span>
          </div>
          <nav
            class="mt-6 flex flex-wrap items-center justify-center gap-x-7 gap-y-2 text-[13px] tracking-[0.06em] uppercase text-zinc-400"
            aria-label="Primary"
          >
            <a
              href="https://nousergon.ai/"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-zinc-100 transition"
            >
              Home
            </a>
            <a
              href="https://github.com/nousergon/vires"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-zinc-100 transition"
            >
              GitHub
            </a>
          </nav>
          <h1 class="mt-8 text-2xl md:text-4xl font-semibold tracking-tight text-zinc-100 text-balance">
            Strength training that adapts to you.
          </h1>
          <p class="mt-5 text-sm md:text-base text-zinc-400 leading-relaxed max-w-xl text-pretty">
            Log your lifts, build routines, and train with an AI coach that plans around your
            goals &mdash; and replans when life happens.
          </p>

          <!-- Waitlist capture -->
          <form
            id="waitlist-form"
            class="mt-8 w-full max-w-md flex flex-col sm:flex-row gap-2"
            novalidate
          >
            <label for="email" class="sr-only">Email address</label>
            <input
              id="email"
              name="email"
              type="email"
              required
              autocomplete="email"
              placeholder="you@example.com"
              class="flex-1 rounded-md border border-white/15 bg-white/5 px-4 py-2.5 text-sm text-zinc-100 placeholder:text-zinc-500 outline-none transition focus:border-emerald-400/70 focus:bg-white/[0.07]"
            />
            <!-- Honeypot: bots fill this; humans never see it. Submissions with it set are dropped. -->
            <input
              type="text"
              name="website"
              tabindex="-1"
              autocomplete="off"
              class="hidden"
              aria-hidden="true"
            />
            <button
              type="submit"
              class="shrink-0 rounded-md bg-emerald-600 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-emerald-500 disabled:opacity-50"
            >
              Join the beta
            </button>
          </form>
          <p id="waitlist-msg" class="mt-3 text-xs min-h-[1rem]" role="status" aria-live="polite"></p>
          <p class="mt-1 text-[11px] text-zinc-500">
            A private beta is coming. We email you when it opens &mdash; nothing else.
          </p>
        </div>
      </section>

      <!-- What the beta delivers -->
      <section class="px-6 py-12 border-t border-white/10">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-emerald-400 text-center">
            What the beta includes
          </h2>
          <div class="mt-8 grid gap-px sm:grid-cols-2 lg:grid-cols-3 bg-white/10 rounded-lg overflow-hidden border border-white/10">
            {
              features.map((f) => (
                <div class="bg-black p-5">
                  <h3 class="text-sm font-semibold text-zinc-100">{f.name}</h3>
                  <p class="mt-1.5 text-xs text-zinc-400 leading-relaxed">{f.body}</p>
                </div>
              ))
            }
          </div>
          <p class="mt-6 text-center text-xs text-zinc-500 max-w-xl mx-auto">
            Open source under AGPL-3.0 &mdash; the code is on
            <a
              href="https://github.com/nousergon/vires"
              target="_blank"
              rel="noopener noreferrer"
              class="text-zinc-400 hover:text-zinc-100 transition underline underline-offset-2"
            >
              GitHub</a
            >. Your training data stays yours.
          </p>
        </div>
      </section>
    </main>

    <footer class="border-t border-white/10">
      <div class="max-w-5xl mx-auto px-6 py-8 text-xs text-zinc-500">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3">
          <div>
            <a
              href="https://nousergon.ai/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-zinc-400 hover:text-zinc-100 transition"
            >
              Nous Ergon
            </a>
            &mdash; an applied AI lab
            &middot;
            <a href="mailto:nous@nousergon.ai" class="text-zinc-400 hover:text-zinc-100 transition">
              nous@nousergon.ai
            </a>
          </div>
          <div class="text-zinc-600">&nu;&omicron;&upsilon;&sigmaf; &epsilon;&rho;&gamma;&omicron;&nu;</div>
        </div>
        <p class="mt-4 text-zinc-600">Training software &mdash; not medical advice.</p>
      </div>
    </footer>

    <script>
      // Progressive enhancement: post the waitlist signup to the Pages Function and
      // swap inline status copy. The form is a normal POST target, so a no-JS submit
      // still reaches /api/waitlist (which returns JSON either way).
      const form = document.getElementById('waitlist-form') as HTMLFormElement | null;
      const msg = document.getElementById('waitlist-msg');
      const button = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;

      function setMsg(text: string, ok: boolean) {
        if (!msg) return;
        msg.textContent = text;
        msg.className = `mt-3 text-xs min-h-[1rem] ${ok ? 'text-emerald-400' : 'text-rose-400'}`;
      }

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const data = new FormData(form);
        const email = String(data.get('email') ?? '').trim();
        if (!email || !email.includes('@')) {
          setMsg('Please enter a valid email address.', false);
          return;
        }
        if (button) button.disabled = true;
        setMsg('', true);
        try {
          const res = await fetch('/api/waitlist', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, website: data.get('website') ?? '' }),
          });
          if (res.ok) {
            form.reset();
            setMsg("You're on the list. We'll be in touch.", true);
          } else {
            const body = (await res.json().catch(() => ({}))) as { error?: string };
            setMsg(body.error ?? 'Something went wrong — please try again.', false);
            if (button) button.disabled = false;
          }
        } catch {
          setMsg('Network error — please try again.', false);
          if (button) button.disabled = false;
        }
      });
    </script>
  </body>
</html>
