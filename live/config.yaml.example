# ─────────────────────────────────────────────────────────────────────────────
# DESCRIPTIVE / DOCUMENTATION ONLY
#
# Production reads the live config from live/config.yaml on the dashboard
# EC2 instance (gitignored, lives in ~/alpha-engine-dashboard/live/
# config.yaml on the host that runs nous-ergon-live.service — the live
# console at live.nousergon.ai). The live config is NOT in alpha-engine-
# config (unlike most other modules) — it's per-instance state on the
# EC2 host.
#
# (Note: the nousergon.ai apex itself is served by Cloudflare Pages from
# the Astro build in marketing/, NOT by any EC2 systemd unit. Pre-2026-
# 05-22 this file's header referred to a now-retired nous-ergon-public.
# service that served the apex from EC2; that path is gone. Only live.
# nousergon.ai and console.nousergon.ai are EC2-served.)
#
# Edits to this .example file affect ONLY:
#   1. New-environment bootstrap (copies this template to config.yaml), and
#   2. Public-repo schema documentation for the live-console config surface.
#
# Edits here have ZERO effect on the running live console. To change a
# runtime value, SSH to the dashboard host and edit ~/alpha-engine-
# dashboard/live/config.yaml directly, then restart nous-ergon-live.
# service.
# ─────────────────────────────────────────────────────────────────────────────

s3:
  trades_bucket: alpha-engine-executor
  research_bucket: alpha-engine-research

paths:
  eod_pnl: trades/eod_pnl.csv
  trades_full: trades/trades_full.csv

cache_ttl:
  trades: 900     # 15 min
  research: 3600  # 1 hour

# Starting capital for cash calculation (NAV - sum(positions) = cash)
starting_capital: 1000000

# Override inception date if the paper trading account is reset.
# Set to the first trading day after reset. Leave blank to auto-detect
# from earliest eod_pnl row.
# inception_date: "2026-03-09"
