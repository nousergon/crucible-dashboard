# ─────────────────────────────────────────────────────────────────────────────
# DESCRIPTIVE / DOCUMENTATION ONLY
#
# Production reads the live config from public/config.yaml on the dashboard
# EC2 instance (gitignored, lives in ~/alpha-engine-dashboard/public/
# config.yaml on the host that runs nous-ergon-public.service — the public
# site at nousergon.ai). The live config is NOT in alpha-engine-config
# (unlike most other modules) — it's per-instance state on the EC2 host.
#
# Edits to this .example file affect ONLY:
#   1. New-environment bootstrap (copies this template to config.yaml), and
#   2. Public-repo schema documentation for the public-site config surface.
#
# Edits here have ZERO effect on the live public site. To change a runtime
# value, SSH to the dashboard host and edit ~/alpha-engine-dashboard/public/
# config.yaml directly, then restart nous-ergon-public.service.
# ─────────────────────────────────────────────────────────────────────────────

s3:
  trades_bucket: alpha-engine-executor
  research_bucket: alpha-engine-research

paths:
  eod_pnl: trades/eod_pnl.csv
  trades_full: trades/trades_full.csv

cache_ttl:
  trades: 900     # 15 min
  research: 3600  # 1 hour

# Starting capital for cash calculation (NAV - sum(positions) = cash)
starting_capital: 1000000

# Override inception date if the paper trading account is reset.
# Set to the first trading day after reset. Leave blank to auto-detect
# from earliest eod_pnl row.
# inception_date: "2026-03-09"
