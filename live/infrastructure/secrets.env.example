# Copy this file to secrets.env and fill in your values.
# secrets.env is gitignored — never commit it.

# Cloudflare API Token (dash.cloudflare.com/profile/api-tokens → Create Custom Token)
# Permissions: Zone > DNS > Edit, Zone > SSL and Certificates > Edit, Account > Access: Apps and Policies > Edit
CF_API_TOKEN=

# Cloudflare Origin CA Key (dash.cloudflare.com/profile/api-tokens → scroll to "Origin CA Key" → View)
CF_ORIGIN_CA_KEY=

# EC2 Elastic IP (or public IP if already assigned)
EC2_IP=

# EC2 Instance ID (e.g., i-0abc123def456)
EC2_INSTANCE_ID=

# Your email for Cloudflare Access whitelist
AUTH_EMAIL=
