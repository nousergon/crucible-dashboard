# Bootstrap-time secrets for the public-site EC2 setup scripts
# (setup-cloudflare.sh + setup-aws.sh + deploy-ec2.sh). These only run
# during initial provisioning of a fresh EC2 — they are NOT runtime
# secrets and are NOT read by the Streamlit app at boot.
#
# As of 2026-05-21, the canonical source is AWS SSM Parameter Store at:
#   /alpha-engine/dashboard/secrets/{CF_API_TOKEN,CF_ORIGIN_CA_KEY,
#                                    AUTH_EMAIL,EC2_IP,EC2_INSTANCE_ID}
# All entries are SecureString. To fetch for a fresh bootstrap:
#   eval "$(aws ssm get-parameters-by-path \
#       --path /alpha-engine/dashboard/secrets \
#       --with-decryption \
#       --query 'Parameters[].[Name,Value]' --output text \
#       | awk '{n=split($1,a,\"/\"); print a[n]\"=\\\"\"$2\"\\\"\"}')"
#
# This file (.example) stays for documentation; the real secrets.env
# is no longer needed on the EC2 — it was migrated to SSM. The format
# below is preserved in case you need to reconstruct a local .env file
# for testing (which should not happen in normal operation).

# Cloudflare API Token (dash.cloudflare.com/profile/api-tokens → Create Custom Token)
# Permissions: Zone > DNS > Edit, Zone > SSL and Certificates > Edit, Account > Access: Apps and Policies > Edit
CF_API_TOKEN=

# Cloudflare Origin CA Key (dash.cloudflare.com/profile/api-tokens → scroll to "Origin CA Key" → View)
CF_ORIGIN_CA_KEY=

# EC2 Elastic IP (or public IP if already assigned)
EC2_IP=

# EC2 Instance ID (e.g., i-0abc123def456)
EC2_INSTANCE_ID=

# Your email for Cloudflare Access whitelist
AUTH_EMAIL=
